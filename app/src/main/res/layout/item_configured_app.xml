<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/card_bg"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#ECECF6"
    app:strokeWidth="1dp"
    app:contentPadding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/configIcon"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:contentDescription="应用图标"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:shrinkColumns="0">

                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/configName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/configHealth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:ellipsize="end"
                        android:maxWidth="112dp"
                        android:maxLines="1"
                        android:text="线程未发现 · 将复查"
                        android:textColor="@color/status_warn"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </TableRow>
            </TableLayout>

            <TextView
                android:id="@+id/configPkg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="middle"
                android:maxLines="1"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchJankBoost"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_gravity="center_vertical"
            android:button="@null"
            android:gravity="center"
            android:minHeight="48dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="卡顿时提速"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnView"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_icon_button_soft"
            android:contentDescription="查看配置"
            android:padding="9dp"
            android:scaleType="center"
            android:src="@drawable/ic_visibility" />

        <ImageButton
            android:id="@+id/btnRemove"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_button_danger"
            android:contentDescription="删除配置"
            android:padding="9dp"
            android:scaleType="center"
            android:src="@drawable/ic_delete_red" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
