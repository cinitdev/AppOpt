<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_card"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="10dp"
    android:paddingEnd="20dp"
    android:paddingBottom="18dp">

    <View
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_banner" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="相似线程组怎么算"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="带数字后缀的线程会先合成一组，例如 Job.worker 1 / 2 记为 Job.worker*。这里只决定这组 AVG 怎么算；MAX 始终取组内最高峰值"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/modeMaxMember"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_action_row"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/modeMaxMemberTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="平均负载取最高"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="默认推荐。AVG 取这一组里最忙的单个线程，MAX 取组内最高峰值。适合避免很多低负载线程被加起来后误判为重载"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/modeSum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_action_row"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/modeSumTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="平均负载相加"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="更激进。AVG 会累加这一组里的所有线程，MAX 仍取组内最高峰值。适合多个同名工作线程一起承担主要负载的游戏，但更容易升到中高性能核心"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/modeCancel"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="取消" />
</LinearLayout>
