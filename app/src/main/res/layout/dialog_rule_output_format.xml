<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_card"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp">

        <View
            android:layout_width="42dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_banner" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="校准规则生成格式"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="只改变规则写入排版，不改变绑核效果。旧区块格式会自动转换为原作者格式"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <RelativeLayout
            android:id="@+id/formatLegacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_action_row"
            android:clickable="true"
            android:descendantFocusability="blocksDescendants"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="14dp">

            <TextView
                android:id="@+id/formatLegacyTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@id/formatLegacySelected"
                android:text="旧版单行格式（默认）"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/formatLegacyTitle"
                android:layout_marginTop="4dp"
                android:layout_toStartOf="@id/formatLegacySelected"
                android:fontFamily="monospace"
                android:text="com.tencent.mm{RenderThread}=6-7&#10;com.tencent.mm:push=0-3&#10;com.tencent.mm=0-3"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/formatLegacySelected"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="已选择"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                app:tint="@color/brand_primary" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/formatAuthorBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_action_row"
            android:clickable="true"
            android:descendantFocusability="blocksDescendants"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="14dp">

            <TextView
                android:id="@+id/formatAuthorBlockTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@id/formatAuthorBlockSelected"
                android:text="原作者区块格式"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/formatAuthorBlockTitle"
                android:layout_marginTop="4dp"
                android:layout_toStartOf="@id/formatAuthorBlockSelected"
                android:fontFamily="monospace"
                android:text="com.tencent.mm=0-3 {&#10;    RenderThread=6-7&#10;}&#10;com.tencent.mm:push=0-3"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/formatAuthorBlockSelected"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="已选择"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                app:tint="@color/brand_primary" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/formatCompactExtendedBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_action_row"
            android:clickable="true"
            android:descendantFocusability="blocksDescendants"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="14dp">

            <TextView
                android:id="@+id/formatCompactExtendedBlockTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@id/formatCompactExtendedBlockSelected"
                android:text="扩展区块格式"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/formatCompactExtendedBlockTitle"
                android:layout_marginTop="4dp"
                android:layout_toStartOf="@id/formatCompactExtendedBlockSelected"
                android:fontFamily="monospace"
                android:text="com.tencent.mm{&#10;    RenderThread=6-7&#10;    :push=0-3&#10;}=0-3"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/formatCompactExtendedBlockSelected"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="已选择"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                app:tint="@color/brand_primary" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/formatTaggedBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_action_row"
            android:clickable="true"
            android:descendantFocusability="blocksDescendants"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="14dp">

            <TextView
                android:id="@+id/formatTaggedBlockTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@id/formatTaggedBlockSelected"
                android:text="类型标签区块"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/formatTaggedBlockTitle"
                android:layout_marginTop="4dp"
                android:layout_toStartOf="@id/formatTaggedBlockSelected"
                android:fontFamily="monospace"
                android:text="com.tencent.mm={&#10;    thread:RenderThread=6-7&#10;    process:push=0-3&#10;    fallback=0-6&#10;}"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/formatTaggedBlockSelected"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="已选择"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                app:tint="@color/brand_primary" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/formatNaturalBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_action_row"
            android:clickable="true"
            android:descendantFocusability="blocksDescendants"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="14dp">

            <TextView
                android:id="@+id/formatNaturalBlockTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@id/formatNaturalBlockSelected"
                android:text="自然语句区块"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/formatNaturalBlockTitle"
                android:layout_marginTop="4dp"
                android:layout_toStartOf="@id/formatNaturalBlockSelected"
                android:fontFamily="monospace"
                android:text="app com.tencent.mm fallback 0-6 {&#10;    thread RenderThread=6-7&#10;    process push=0-3&#10;}"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/formatNaturalBlockSelected"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="已选择"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                app:tint="@color/brand_primary" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/formatNestedBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_action_row"
            android:clickable="true"
            android:descendantFocusability="blocksDescendants"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="14dp">

            <TextView
                android:id="@+id/formatNestedBlockTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@id/formatNestedBlockSelected"
                android:text="分类嵌套区块"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/formatNestedBlockTitle"
                android:layout_marginTop="4dp"
                android:layout_toStartOf="@id/formatNestedBlockSelected"
                android:fontFamily="monospace"
                android:text="com.tencent.mm={&#10;    threads {&#10;        RenderThread=6-7&#10;    }&#10;    processes {&#10;        push=0-3&#10;    }&#10;    fallback=0-6&#10;}"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/formatNestedBlockSelected"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="已选择"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                app:tint="@color/brand_primary" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/formatFunctionBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_action_row"
            android:clickable="true"
            android:descendantFocusability="blocksDescendants"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="14dp">

            <TextView
                android:id="@+id/formatFunctionBlockTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@id/formatFunctionBlockSelected"
                android:text="函数式格式"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/formatFunctionBlockTitle"
                android:layout_marginTop="4dp"
                android:layout_toStartOf="@id/formatFunctionBlockSelected"
                android:fontFamily="monospace"
                android:text="app(com.tencent.mm, 0-6) {&#10;    thread(RenderThread, 6-7)&#10;    process(push, 0-3)&#10;}"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/formatFunctionBlockSelected"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="已选择"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                app:tint="@color/brand_primary" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/formatYaml"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_action_row"
            android:clickable="true"
            android:descendantFocusability="blocksDescendants"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="14dp">

            <TextView
                android:id="@+id/formatYamlTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@id/formatYamlSelected"
                android:text="YAML 风格"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/formatYamlTitle"
                android:layout_marginTop="4dp"
                android:layout_toStartOf="@id/formatYamlSelected"
                android:fontFamily="monospace"
                android:text="com.tencent.mm:&#10;    threads:&#10;        RenderThread: 6-7&#10;    processes:&#10;        push: 0-3&#10;    fallback: 0-6"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/formatYamlSelected"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="已选择"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                app:tint="@color/brand_primary" />
        </RelativeLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/formatCancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="取消" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
