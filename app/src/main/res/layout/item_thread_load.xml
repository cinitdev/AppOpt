<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="14dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/loadType"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:background="@drawable/bg_rule_type_thread"
            android:gravity="center"
            android:minWidth="52dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="线程"
            android:textColor="@color/brand_primary_dark"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/threadName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/threadAvg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_history_metric"
            android:fontFamily="monospace"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:textColor="@color/brand_primary_dark"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/threadMax"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:background="@drawable/bg_history_metric"
            android:fontFamily="monospace"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_marginTop="9dp"
        android:background="@drawable/bg_history_sparkline"
        android:padding="6dp">

        <top.suto.appopt.SparklineView
            android:id="@+id/threadSpark"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/childThreadsToggle"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="9dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="内部线程负载"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/childThreadCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <ImageView
            android:id="@+id/childThreadsArrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:contentDescription="展开或收起子进程线程"
            android:padding="5dp"
            android:src="@drawable/ic_chevron_down"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/childThreadsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_child_thread_table"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="5dp"
        android:paddingEnd="10dp"
        android:paddingBottom="5dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="线程名称"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />

            <TextView
                android:layout_width="62dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="AVG"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="62dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="MAX"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/bg_policy_divider" />

        <LinearLayout
            android:id="@+id/childThreadsRows"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_policy_divider" />
</LinearLayout>
